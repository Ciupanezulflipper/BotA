# BotA runtime BEGIN
CRON_TZ=UTC
*/15 * * * * bash -lc '. "/data/data/com.termux/files/home/BotA/.env.runtime"; if "/data/data/com.termux/files/home/BotA/tools/market_open.sh" >/dev/null 2>&1; then export TELEGRAM_BOT_TOKEN="${TELEGRAM_BOT_TOKEN}"; export TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID}"; DRY_RUN_MODE=0 TELEGRAM_ENABLED=1 TELEGRAM_MIN_SCORE=70 TELEGRAM_COOLDOWN_SECONDS=1800 FILTER_SCORE_MIN=65 FILTER_SCORE_MIN_ALL=65 TELEGRAM_TIER_YELLOW_MIN=70 TELEGRAM_TIER_YELLOW_MIN_INT=70 TELEGRAM_TIER_GREEN_MIN=75 TELEGRAM_TIER_GREEN_MIN_INT=75 CANDLE_MAX_AGE_SECS=2700 PAIRS="EURUSD GBPUSD" TIMEFRAMES="M15" timeout -k 30s 12m bash "/data/data/com.termux/files/home/BotA/tools/signal_watcher_pro.sh" --once; else echo "[SIGNALS] market_closed_or_gate_failed -> watcher skipped"; fi' >> /data/data/com.termux/files/home/BotA/logs/cron.signals.log 2>&1
*/15 * * * * bash -lc '. "/data/data/com.termux/files/home/BotA/.env.runtime"; timeout -k 30s 12m bash "/data/data/com.termux/files/home/BotA/tools/run_shadow_manager.sh"' >> /data/data/com.termux/files/home/BotA/logs/cron.shadow.log 2>&1
13,28,43,58 * * * * bash -lc '. "/data/data/com.termux/files/home/BotA/.env.runtime"; mkdir -p "/data/data/com.termux/files/home/BotA/state"; PAIRS="EURUSD GBPUSD USDJPY" TIMEFRAMES="M15 H1 H4 D1" FETCH_RETRIES=3 FETCH_BACKOFF_BASE=5 FETCH_BACKOFF_MAX=20 FETCH_MIN_GAP_SECS=1 timeout -k 30s 10m flock -n "/data/data/com.termux/files/home/BotA/state/indicators_updater.lock" bash "/data/data/com.termux/files/home/BotA/tools/indicators_updater.sh" || echo "[UPDATER] skipped_or_timeout_or_failed rc=$?"' >> /data/data/com.termux/files/home/BotA/logs/cron.indicators.log 2>&1
6 5 * * * bash -lc '. "/data/data/com.termux/files/home/BotA/.env.runtime"; python3 "/data/data/com.termux/files/home/BotA/tools/alerts_to_trades.py"' >> /data/data/com.termux/files/home/BotA/logs/cron.trades.log 2>&1
6 5 * * * python3 /data/data/com.termux/files/home/BotA/tools/pause_guard.py >> /data/data/com.termux/files/home/BotA/logs/cron.pause.log 2>&1
0 * * * * bash /data/data/com.termux/files/home/BotA/tools/heartbeat.sh >> /data/data/com.termux/files/home/BotA/logs/cron.heartbeat.log 2>&1
4 * * * * bash /data/data/com.termux/files/home/BotA/tools/autostatus.sh >> /data/data/com.termux/files/home/BotA/logs/cron.autostatus.log 2>&1
0 1 * * 0 bash -lc '. "/data/data/com.termux/files/home/BotA/.env.runtime"; python3 "/data/data/com.termux/files/home/BotA/tools/signal_accuracy.py"' >> /data/data/com.termux/files/home/BotA/logs/cron.accuracy.log 2>&1
*/5 * * * * bash /data/data/com.termux/files/home/BotA/tools/bota_supervisor.sh >> /data/data/com.termux/files/home/BotA/logs/cron.supervisor.log 2>&1
55 * * * * bash -lc 'cd /data/data/com.termux/files/home/BotA && bash tools/clock_drift_check.sh >> /data/data/com.termux/files/home/BotA/logs/cron.clock_drift.log 2>&1'
*/15 * * * * bash /data/data/com.termux/files/home/BotA/tools/run_signal_closer_live.sh >> /data/data/com.termux/files/home/BotA/logs/cron.closer.log 2>&1
10 * * * * cd /data/data/com.termux/files/home/BotA && /data/data/com.termux/files/usr/bin/bash /data/data/com.termux/files/home/BotA/tools/daily_summary_server_gate.sh >> /data/data/com.termux/files/home/BotA/logs/cron.daily.log 2>&1
*/5 * * * * cd /data/data/com.termux/files/home/BotA && /data/data/com.termux/files/home/BotA/tools/run_runtime_health_push.sh >> /data/data/com.termux/files/home/BotA/logs/cron.runtime_health_push.wrapper.log 2>&1
# BotA runtime END
