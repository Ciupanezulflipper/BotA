@dataclass
class Candle:
    time: datetime
    open: float
    high: float
    low: float
    close: float


# ─────────────────────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────────────────────


def now_utc() -> datetime:
    return datetime.now(timezone.utc)


def to_iso(dt: datetime) -> str:
    return dt.astimezone(timezone.utc).isoformat()


def parse_ts(value: str) -> datetime:
    return (
        datetime.fromisoformat(str(value).replace("Z", "+00:00"))
        .astimezone(timezone.utc)
    )


def pip_size(pair: str) -> float:
    return 0.01 if pair.upper().endswith("JPY") else 0.0001


def pips_between(a: float, b: float, pair: str) -> float:
    return round(abs(a - b) / pip_size(pair), 1)


def favorable_mfe_pips(c: Candle, entry: float, direction: str, pair: str) -> float:
    ps = pip_size(pair)
    if direction.upper() == "SELL":
        return max(0.0, round((entry - c.low) / ps, 1))
    return max(0.0, round((c.high - entry) / ps, 1))


def oanda_instrument(pair: str) -> str:
    clean = pair.upper().replace("/", "").replace("_", "")
    return f"{clean[:3]}_{clean[3:]}" if len(clean) == 6 else pair.upper()


def write_heartbeat(status: str, detail: str = "") -> None:
    with HEARTBEAT_PATH.open("a", encoding="utf-8") as f:
        f.write(f"{to_iso(now_utc())} | {status} | {detail}\n")


def check_previous_heartbeat(max_gap_min: int = 35) -> None:
    if not HEARTBEAT_PATH.exists():
        return
    try:
        last = (
            HEARTBEAT_PATH.read_text(encoding="utf-8", errors="ignore")
            .strip().splitlines()[-1]
        )
        gap = (now_utc() - parse_ts(last.split(" | ")[0])).total_seconds() / 60.0
        if gap > max_gap_min:
            log.warning(
                "MISSED_CYCLE: last heartbeat %.1f min ago (expected ≤15)", gap
            )
    except Exception:
        pass


